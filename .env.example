# FastAPI
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=sqlite:///./data/app.db

# Azure OpenAI (do NOT commit real values)
AZURE_OPENAI_ENDPOINT= 
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Local ASR model exports
WAV2VEC_MODEL_PATH=app/models/wav2vec2_ctc
WHISPER_SMALL_MODEL_PATH=app/models/small
# This path can remain set while training is incomplete; it is reported unavailable until it is a completed export.
WHISPER_MEDIUM_MODEL_PATH=app/models/M

# Google Speech-to-Text settings are not used by the local whisper-small model.
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_SPEECH_LOCATION=us
GOOGLE_SPEECH_MODEL=chirp_3
GOOGLE_SPEECH_LANGUAGES=km-KH,en-US
